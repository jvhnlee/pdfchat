profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   It makes the version used in development available to other developers.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions.
#   See https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions.
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/

